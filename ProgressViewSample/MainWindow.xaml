<Window x:Class="ProgressViewSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProgressViewSample"
        xmlns:converters="clr-namespace:ProgressViewSample.Converters"
        xmlns:viewModels="clr-namespace:ProgressViewSample.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.DataContext>
        <viewModels:MainWindowViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StyleToIndeterminateConverter x:Key="StyleToIndeterminateConverter"/>
    </Window.Resources>

    <Grid>
        <Button Content="데이터 로드" 
                Command="{Binding LoadDataCommand}"
                Width="120" Height="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
        
        <Border Background="#CC000000" 
                Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
                <TextBlock Text="{Binding ProgressMessage}" 
                           Foreground="White" 
                           TextAlignment="Center"
                           Margin="5"/>

                <ProgressBar Height="30" 
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             IsIndeterminate="{Binding ProgressStyle, Converter={StaticResource StyleToIndeterminateConverter}}"
                             Margin="5"/>

                <Button Content="취소" 
                        Command="{Binding DismissProgressCommand}"
                        Width="80" Height="30"
                        Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
