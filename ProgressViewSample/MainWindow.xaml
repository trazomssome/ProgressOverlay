<Window x:Class="ProgressViewSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProgressViewSample"
        xmlns:controls="clr-namespace:ProgressViewSample.Controls"
        xmlns:viewModels="clr-namespace:ProgressViewSample.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.DataContext>
        <viewModels:MainWindowViewModel/>
    </Window.DataContext>

    <Grid>

        <Button Content="데이터 로드" 
                Command="{Binding LoadDataCommand}"
                Width="120" Height="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
        
        <controls:ProgressOverlay 
            IsProgressVisible="{Binding IsProgressVisible}"
            ProgressValue="{Binding ProgressValue}"
            ProgressMessage="{Binding ProgressMessage}"
            ProgressStyle="{Binding ProgressStyle}"
            DismissCommand="{Binding DismissProgressCommand}" />
    </Grid>
</Window>
